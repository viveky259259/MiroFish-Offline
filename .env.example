# =============================================================
# MiroFish-Offline Configuration
# =============================================================
# LLM runs on Groq cloud; embeddings run on local Ollama.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== LLM Configuration (Groq cloud — OpenAI-compatible) =====
# Get your API key at https://console.groq.com/keys
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=qwen/qwen3-32b

# ===== Groq Rate Limits (free tier) =====
# Adjust if you upgrade your Groq plan
GROQ_RPM=30
GROQ_TPM=6000

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Embedding Configuration =====
# Uses local Ollama for embeddings (nomic-embed-text is ~274MB)
# Run: ollama pull nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_BASE_URL=http://localhost:11434

# ===== Simulation LLM (local Ollama — bulk agent calls) =====
# Cheaper local model for high-volume simulation agent responses
# Groq's free tier has tight rate limits, so simulations run locally
SIM_LLM_API_KEY=ollama
SIM_LLM_BASE_URL=http://localhost:11434/v1
SIM_LLM_MODEL_NAME=qwen3.5:2b
