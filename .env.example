# =============================================================
# MiroFish-Offline Configuration
# =============================================================
# Fully cloud setup — no local Ollama required.
# Copy this file to .env and adjust values for your setup.
# =============================================================

# ===== LLM Configuration (Groq cloud — OpenAI-compatible) =====
# Get your API key at https://console.groq.com/keys
LLM_API_KEY=gsk_your_groq_api_key_here
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_NAME=qwen/qwen3-32b

# ===== Simulation LLM (Groq — lighter model for bulk agent calls) =====
# Falls back to LLM_API_KEY if not set. llama-3.1-8b-instant has higher rate limits.
# SIM_LLM_API_KEY=gsk_your_groq_api_key_here  # defaults to LLM_API_KEY
# SIM_LLM_BASE_URL=https://api.groq.com/openai/v1
# SIM_LLM_MODEL_NAME=llama-3.1-8b-instant

# ===== Groq Rate Limits (free tier) =====
# Adjust if you upgrade your Groq plan
GROQ_RPM=30
GROQ_TPM=6000

# ===== Neo4j Configuration =====
# For Docker: use service name "neo4j" instead of "localhost"
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mirofish

# ===== Embedding Configuration (Jina AI — free tier: 1M tokens/month) =====
# Get your API key at https://jina.ai (free signup)
EMBEDDING_API_KEY=jina_your_api_key_here
# EMBEDDING_MODEL=jina-embeddings-v2-base-en  # 768 dims, matches Neo4j schema
